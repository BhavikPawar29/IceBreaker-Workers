{
  "name": "icebreaker-workers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "wrangler dev",
    "check": "wrangler deploy --dry-run",
    "typegen": "wrangler types src/worker-configuration.d.ts",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typegen && npm run check && npm run typecheck && npm run test",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.16",
    "@types/node": "^24.0.7",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.101.0"
  }
}
